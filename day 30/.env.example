# День 30 — приватный LLM-сервис. Скопируйте в .env и поменяйте токены.

# Авторизация: список токенов через запятую. Сгенерировать: openssl rand -hex 16
API_TOKENS=change-me

# Сеть
BIND_HOST=0.0.0.0
PORT=8030

# Модели (должны быть скачаны: ollama pull …)
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=qwen2.5:1.5b
EMBED_MODEL=nomic-embed-text

# Базовые ограничения (отдаются клиенту через GET /v1/limits)
RATE_LIMIT_PER_MIN=12
RATE_LIMIT_BURST=5
NUM_CTX=4096
MAX_ANSWER_TOKENS=512
MAX_INPUT_CHARS=2000
MAX_CONCURRENT=2
MAX_WAITING=8

# Тюнинг под слабый VPS (1 vCPU / 2 GB, проверено на реальном деплое):
# с дефолтами Ollama ловит OOM-kill (KV-кэш 4096 × 2 слота), а ответ занимает 2–4 мин.
# Плюс на сервере: OLLAMA_NUM_PARALLEL=1 в юните ollama (см. deploy/setup-vps.sh).
# NUM_CTX=2048
# MAX_ANSWER_TOKENS=256
# FRAGMENTS_CHAR_BUDGET=2500
# HISTORY_CHAR_BUDGET=2500
# MAX_CONCURRENT=1
# QUEUE_TIMEOUT_MS=180000

# Для ./run.sh verify против удалённого сервера:
# VERIFY_BASE_URL=http://<vps-ip>:8030
# VERIFY_TOKEN=change-me
