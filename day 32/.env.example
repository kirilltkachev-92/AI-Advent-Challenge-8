# День 32 — автоматизация ревью кода.

# Локальные прогоны (review): ключ DeepSeek. Также ищется в ../day 25/.env,
# ../day 22/.env и ../day 17/.env. В GitHub Actions — secrets.DEEPSEEK_API_KEY.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Эмбеддинги: Ollama (ollama pull nomic-embed-text)
# OLLAMA_BASE_URL=http://localhost:11434
# EMBED_MODEL=nomic-embed-text

# Ревью
# TOP_K=6                # сколько фрагментов контекста на ревью
# MAX_DIFF_CHARS=40000   # бюджет диффа в промпте
