# День 22 — первый RAG-запрос. Эмбеддинги и поиск — локальная Ollama,
# сам агент (оба режима) и судья — DeepSeek, поэтому ключ обязателен.
#
# Подготовка: brew install ollama && ollama serve && ollama pull nomic-embed-text

# --- Агент и судья (DeepSeek, OpenAI-совместимый) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- Эмбеддинги (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# EMBED_MODEL=nomic-embed-text

# --- RAG ---
# RAG_STRATEGY=structure  # какой индекс строить/использовать: structure | fixed
# TOP_K=4                 # сколько чанков идет в контекст
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200

# --- Каталоги ---
# DOCS_DIR=docs
# OUTPUT_DIR=output
