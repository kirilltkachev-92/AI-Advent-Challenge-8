# Базовый URL локального сервера Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Матрица моделей: база Дней 26–28, её же квант поменьше и крошечная модель
BASE_MODEL=qwen2.5:14b
QUANT_MODEL=qwen2.5:14b-instruct-q3_K_M
MINI_MODEL=qwen2.5:0.5b

# Сколько раз каждый кейс уходит каждому профилю (стабильность)
STABILITY_RUNS=2

# Для быстрых прогонов при отладке: взять только первые N кейсов
# CASE_LIMIT=2
