# День 17 — свой MCP-сервер вокруг Open-Meteo + агент на DeepSeek.
#
# Open-Meteo бесплатный и без ключа — для самого MCP-сервера ничего не нужно.
# Ключ требуется только агенту-LLM (DeepSeek). Его можно взять из .env прошлых дней.

# --- Агент (DeepSeek, OpenAI-совместимый) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- MCP-сервер ---
# Порт встроенного локального сервера (по умолчанию 8765).
# MCP_PORT=8765
#
# Если сервер вынесен наружу (например, задеплоен на VPS) — укажите его URL,
# тогда приложение не будет поднимать встроенный сервер, а подключится к этому:
# MCP_SERVER_URL=http://YOUR_VPS_IP:8765/mcp
