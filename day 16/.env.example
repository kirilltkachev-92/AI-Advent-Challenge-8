# День 16 — подключение к MCP-серверу.
#
# По умолчанию (без .env) клиент подключается к публичному MCP Microsoft Learn:
#   https://learn.microsoft.com/api/mcp
# Он бесплатный и не требует ключа, так что задание работает «из коробки».
# Файл .env нужен ТОЛЬКО если хотите подключиться к другому MCP-серверу.

# --- Сменить сервер (необязательно) ---
# MCP_SERVER_URL=https://learn.microsoft.com/api/mcp

# Примеры других публичных серверов без ключа:
# MCP_SERVER_URL=https://knowledge-mcp.global.api.aws         # документация AWS
# MCP_SERVER_URL=https://gitmcp.io/facebook/react             # docs Q&A по репозиторию

# --- Bearer-токен (нужен только серверам с авторизацией, напр. Apify) ---
# MCP_AUTH_TOKEN=xxxxxxxx
