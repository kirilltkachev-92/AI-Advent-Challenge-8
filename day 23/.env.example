# День 23 — реранкинг и фильтрация. Эмбеддинги и поиск — локальная Ollama,
# агент, rewrite, реранкер и судья — DeepSeek, поэтому ключ обязателен.
#
# Подготовка: brew install ollama && ollama serve && ollama pull nomic-embed-text

# --- Агент, rewrite, реранкер, судья (DeepSeek) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- Эмбеддинги (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# EMBED_MODEL=nomic-embed-text

# --- Настройки фильтрации/реранка (тюнинг дня) ---
# CANDIDATES_K=20       # top-K ДО фильтрации (широкая выборка по косинусу)
# FINAL_K=4             # top-K ПОСЛЕ фильтрации (что уходит в контекст; он же baseline)
# SIM_THRESHOLD=0.55    # порог косинуса: дешёвое отсечение нерелевантного до реранка
# RERANK_THRESHOLD=6    # порог балла LLM-реранкера (0–10)

# --- Индекс ---
# RAG_STRATEGY=structure  # structure | fixed
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200

# --- Каталоги ---
# DOCS_DIR=docs
# OUTPUT_DIR=output
