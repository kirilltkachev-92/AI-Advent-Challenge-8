# День 19 — композиция MCP-инструментов (search → summarize → save_to_file).
#
# Википедия бесплатна и без ключа. Ключ нужен агенту (DeepSeek), который из запроса
# пользователя сам выстраивает цепочку вызовов инструментов.

# --- Агент (DeepSeek, OpenAI-совместимый) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- Инструменты ---
# Язык Википедии для поиска (ru/en/…), по умолчанию ru.
# WIKI_LANG=ru
#
# Каталог, куда save_to_file пишет файлы (по умолчанию output).
# OUTPUT_DIR=output
#
# Минимальная пауза между запросами к Википедии, мс (вежливый троттлинг от бана/429).
# По умолчанию 500. Увеличьте (напр. 1000–2000), если Википедия ограничивает запросы.
# WIKI_DELAY_MS=500

# --- MCP-сервер ---
# Порт встроенного локального сервера (по умолчанию 8765).
# MCP_PORT=8765
#
# Если сервер вынесен наружу (например, на VPS) — укажите его URL,
# тогда приложение подключится к нему вместо встроенного:
# MCP_SERVER_URL=http://YOUR_VPS_IP:8765/mcp
