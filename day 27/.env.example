# Базовый URL локального сервера Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Чат-модель и модель эмбеддингов (обе локальные, через ollama pull)
CHAT_MODEL=qwen2.5:14b
EMBED_MODEL=nomic-embed-text

# Путь к HTML-экспорту Telegram (по умолчанию — data-messages.html рядом с проектом)
# EXPORT_PATH=/путь/к/ChatExport/messages.html
