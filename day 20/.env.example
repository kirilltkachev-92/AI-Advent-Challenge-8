# День 20 — оркестрация нескольких MCP-серверов (research / weather / report / storage).
#
# Википедия и Open-Meteo бесплатны и без ключа. Ключ нужен агенту-оркестратору (DeepSeek),
# который из запроса пользователя сам выбирает инструменты с РАЗНЫХ серверов и строит флоу.

# --- Агент (DeepSeek, OpenAI-совместимый) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- Инструменты ---
# Язык Википедии для поиска (ru/en/…), по умолчанию ru.
# WIKI_LANG=ru
#
# Каталог, куда storage-MCP (save_to_file) пишет файлы (по умолчанию output).
# OUTPUT_DIR=output
#
# Минимальная пауза между запросами к Википедии, мс (вежливый троттлинг от бана/429).
# WIKI_DELAY_MS=500

# --- MCP-серверы ---
# Базовый порт. Четыре локальных сервера занимают base..base+3:
#   research-mcp = base, weather-mcp = base+1, report-mcp = base+2, storage-mcp = base+3.
# По умолчанию 8781 (то есть 8781..8784).
# MCP_BASE_PORT=8781
