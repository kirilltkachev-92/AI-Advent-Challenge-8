{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "./gradlew",
      "args": ["classes", "--console=plain"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "JAVA_HOME": "/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
        }
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "DeepSeek Chat",
      "type": "shell",
      "command": "./run.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated"
      }
    }
  ]
}
