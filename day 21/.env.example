# День 21 — индексация документов. Эмбеддинги считает ЛОКАЛЬНАЯ Ollama, ключи не нужны.
#
# Подготовка: brew install ollama && ollama serve && ollama pull nomic-embed-text

# --- Эмбеддинги (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# EMBED_MODEL=nomic-embed-text

# --- Чанкинг ---
# CHUNK_SIZE=1200      # окно фиксированной стратегии, символов
# CHUNK_OVERLAP=200    # перекрытие соседних чанков
# TOP_K=3              # сколько чанков достаём при поиске

# --- Каталоги ---
# DOCS_DIR=docs        # корпус: pdf/md/kt-файлы для индексации
# OUTPUT_DIR=output    # куда пишутся index-*.json и comparison.md

# --- LLM-судья сравнения (опционально) ---
# Без ключа сравнение работает, просто без вердиктов DeepSeek.
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat
