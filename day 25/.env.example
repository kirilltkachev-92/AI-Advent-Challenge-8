# День 25 — мини-чат с RAG + памятью (production-like).
# Эмбеддинги и поиск — локальная Ollama, чат/роутер/реранкер/память/судья — DeepSeek.
#
# Подготовка: brew install ollama && ollama serve && ollama pull nomic-embed-text

# --- DeepSeek (обязателен) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- Эмбеддинги (Ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# EMBED_MODEL=nomic-embed-text

# --- Чат ---
# HISTORY_TURNS=8       # сколько последних ходов идёт в промпт «сырыми» (остальное — память задачи)

# --- Поиск и фильтрация (Дни 23–24) ---
# CANDIDATES_K=20
# FINAL_K=4
# SIM_THRESHOLD=0.55
# RERANK_THRESHOLD=6

# --- Индекс ---
# RAG_STRATEGY=structure
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200

# --- Каталоги ---
# DOCS_DIR=docs
# OUTPUT_DIR=output
