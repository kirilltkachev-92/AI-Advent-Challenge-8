# День 18 — фоновый агент-планировщик погоды (свой MCP + DeepSeek).
#
# Open-Meteo бесплатный и без ключа. Ключ нужен только агенту-сводке (DeepSeek):
# без него планировщик всё равно собирает данные и печатает сводку детерминированно.

# --- Агент (DeepSeek, OpenAI-совместимый) ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# --- Планировщик ---
# Города-наблюдения через запятую (по умолчанию: Париж,Токио).
# WATCH_CITIES=Париж,Токио
#
# Интервалы (сек). Демо-значения короткие; для реального 24/7 — напр. 300 и 3600.
# COLLECT_INTERVAL_SEC=20
# SUMMARY_INTERVAL_SEC=60
#
# Путь к JSON-хранилищу замеров (по умолчанию data/samples.json).
# DATA_FILE=data/samples.json

# --- MCP-сервер ---
# Порт встроенного локального сервера (по умолчанию 8765).
# MCP_PORT=8765
#
# Если сервер вынесен наружу (например, на VPS) — укажите его URL,
# тогда приложение подключится к нему вместо встроенного:
# MCP_SERVER_URL=http://YOUR_VPS_IP:8765/mcp
